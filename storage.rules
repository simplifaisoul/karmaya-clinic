rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Exchange photos: authenticated users can upload, anyone can read
    match /exchange/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Message photos: authenticated users can upload, anyone can read
    match /messages/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
